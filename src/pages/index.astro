---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import { withBase } from '../utils/url';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);
---

<BaseLayout title="Projects">
  <main class="wrap home">
    <section class="hero">
      <h1>Projects</h1>
      <p class="lede">
        存放一些项目的记录与复盘：方法演进的来龙去脉、关键的定量信号，以及结论的成立边界。
      </p>
    </section>

    <section class="post-list">
      {posts.map((post) => (
        <a class="post-card" href={withBase(`/blog/${post.id}/`)}>
          <div class="card-meta">
            <time>{post.data.dateRange ?? post.data.pubDate.toISOString().slice(0, 10)}</time>
            {post.data.tags.slice(0, 3).map((t) => <span class="tag">{t}</span>)}
          </div>
          <h2>{post.data.title}</h2>
          {post.data.subtitle && <p class="card-sub">{post.data.subtitle}</p>}
          {post.data.description && post.data.description.split('\n').filter((s) => s.trim()).map((p) => <p class="card-desc">{p}</p>)}
          <span class="read-more">阅读全文 →</span>
        </a>
      ))}
    </section>
  </main>
</BaseLayout>

<style>
  .hero {
    padding: 3.5em 0 2em;
    border-bottom: 1px solid var(--border);
    margin-bottom: 2em;
  }
  .hero h1 {
    font-size: 2.6em;
    margin: 0 0 0.3em;
    line-height: 1.15;
  }
  .lede {
    color: var(--text-soft);
    font-size: 1.15em;
    margin: 0;
    line-height: 1.7;
  }
  .post-list { display: flex; flex-direction: column; gap: 18px; }
  .post-card {
    display: block;
    text-decoration: none;
    color: inherit;
    border: 1px solid var(--border);
    border-radius: 12px;
    padding: 22px 24px;
    background: var(--bg-soft);
    transition: border-color 0.15s, transform 0.15s;
  }
  .post-card:hover {
    border-color: var(--accent);
    transform: translateY(-2px);
  }
  .card-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-wrap: wrap;
    color: var(--text-soft);
    font-size: 13px;
    margin-bottom: 8px;
  }
  .post-card h2 {
    margin: 0.1em 0 0.3em;
    font-size: 1.45em;
    line-height: 1.3;
  }
  .card-sub {
    color: var(--text);
    font-weight: 500;
    margin: 0 0 0.5em;
  }
  .card-desc {
    color: var(--text-soft);
    margin: 0 0 0.8em;
    font-size: 0.95em;
  }
  .tag {
    background: var(--accent-soft);
    color: var(--accent);
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 12px;
  }
  .read-more { color: var(--accent); font-size: 0.92em; font-weight: 500; }
</style>
