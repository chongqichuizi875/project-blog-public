---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  subtitle?: string;
  description?: string;
  pubDate: Date;
  dateRange?: string;
  tags?: string[];
}
const { title, subtitle, description, pubDate, dateRange, tags = [] } = Astro.props;
const dateStr = pubDate.toISOString().slice(0, 10);
const displayDate = dateRange ?? dateStr;
---

<BaseLayout title={title} description={description}>
  <main class="wrap">
    <article>
      <header class="post-header">
        <div class="post-meta">
          <time datetime={dateStr}>{displayDate}</time>
          {tags.length > 0 && (
            <span class="tags">
              {tags.map((t) => <span class="tag">{t}</span>)}
            </span>
          )}
        </div>
        <h1>{title}</h1>
        {subtitle && <p class="subtitle">{subtitle}</p>}
      </header>
      <div class="post-body">
        <slot />
      </div>
    </article>
  </main>
</BaseLayout>

<style>
  .post-header {
    margin: 2.5em 0 1em;
    padding-bottom: 1.4em;
    border-bottom: 1px solid var(--border);
  }
  .post-header h1 {
    margin: 0.2em 0;
    font-size: 2.1em;
    line-height: 1.25;
  }
  .post-meta {
    display: flex;
    align-items: center;
    gap: 10px;
    flex-wrap: wrap;
    color: var(--text-soft);
    font-size: 14px;
  }
  .subtitle {
    color: var(--text-soft);
    font-size: 1.1em;
    margin: 0.4em 0 0;
  }
  .tags { display: inline-flex; gap: 6px; flex-wrap: wrap; }
  .tag {
    background: var(--accent-soft);
    color: var(--accent);
    padding: 2px 9px;
    border-radius: 999px;
    font-size: 12px;
  }
  .post-body { padding-bottom: 2em; }
</style>

<!-- Mermaid 客户端渲染：把 ```mermaid 代码块转成 SVG 流程图 -->
<script>
  import mermaid from 'mermaid';

  function isDark() {
    return window.matchMedia('(prefers-color-scheme: dark)').matches;
  }

  function renderMermaid() {
    mermaid.initialize({
      startOnLoad: false,
      theme: isDark() ? 'dark' : 'default',
      flowchart: { useMaxWidth: true, htmlLabels: true },
      securityLevel: 'loose',
    });

    // excludeLangs 后，mermaid 块为 <pre><code class="language-mermaid">原文</code></pre>
    const blocks = document.querySelectorAll(
      'code.language-mermaid, pre.language-mermaid > code'
    );
    blocks.forEach((codeEl, i) => {
      const pre = codeEl.closest('pre') ?? codeEl;
      const source = codeEl.textContent ?? '';
      const container = document.createElement('div');
      container.className = 'mermaid';
      container.id = `mermaid-${i}`;
      pre.replaceWith(container);
      mermaid
        .render(`mermaid-svg-${i}`, source)
        .then(({ svg }) => {
          container.innerHTML = svg;
        })
        .catch((err) => {
          container.innerHTML = `<pre style="color:var(--bad)">Mermaid 渲染失败：\n${err}</pre>`;
        });
    });
  }

  // 给所有表格套一层可横向滚动容器，避免宽表撑破移动端
  function wrapTables() {
    document.querySelectorAll('.post-body table').forEach((table) => {
      if (table.parentElement?.classList.contains('table-scroll')) return;
      const wrapper = document.createElement('div');
      wrapper.className = 'table-scroll';
      table.replaceWith(wrapper);
      wrapper.appendChild(table);
    });
  }

  wrapTables();
  renderMermaid();
</script>
