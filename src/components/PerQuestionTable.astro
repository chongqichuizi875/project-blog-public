---
/**
 * AIME25 逐题剖析热力表（§6.4）
 * 展示 30 题：直接解题分、调用 tool 比例、tool 分，并用颜色标出"调用错配"。
 * - 橙色行：难题（直接解题 avg<90）但 controller 没调用 tool（该求助却硬解）
 * - 绿色行：难题且调用了 tool 并获得提升（RL 想要的行为）
 * - 灰色：已答好（avg≥90）
 */
interface Q {
  q: number;
  direct: number;   // 直接解题分
  ratio: number;    // 调用 tool 比例 (0-1)
  tool: number | null; // 调用 tool 分；null = 未调用/NA
}
interface Props {
  data: Q[];
}
const { data } = Astro.props as Props;

function rowClass(d: Q) {
  const hard = d.direct < 90;
  const called = d.ratio > 0 && d.tool !== null;
  if (hard && called && d.tool! > d.direct) return 'green';   // 难题+调用+提升
  if (hard && !called) return 'orange';                        // 难题+没调用
  if (hard && called) return 'green-flat';                     // 难题+调用但没提升
  return 'plain';                                              // 已答好
}
const labels: Record<string, string> = {
  green: '🟢 难题·调用·提升',
  'green-flat': '🟢 难题·调用',
  orange: '🟧 难题·未调用',
  plain: '已答好',
};
---

<div class="pqtable">
  <div class="pq-legend">
    <span class="pq-lg green">🟢 难题（avg&lt;90）+ 调用 tool + 获得提升 —— RL 想要的</span>
    <span class="pq-lg orange">🟧 难题 + 没调用（该求助却硬解）—— 错配，RL 的机会点</span>
    <span class="pq-lg plain">已答好（avg≥90），无需调用</span>
  </div>
  <div class="pq-scroll">
    <table class="pq">
      <thead>
        <tr>
          <th>题号</th>
          <th>直接解题分</th>
          <th>调用 tool 比例</th>
          <th>调用 tool 分</th>
          <th>分类</th>
        </tr>
      </thead>
      <tbody>
        {data.map((d) => {
          const cls = rowClass(d);
          return (
            <tr class={cls}>
              <td class="qn">Q{d.q}</td>
              <td>{d.direct}</td>
              <td>{d.ratio > 0 ? (d.ratio * 100).toFixed(1) + '%' : '—'}</td>
              <td>{d.tool === null ? '—' : d.tool + (d.tool > d.direct ? ' ↑' : '')}</td>
              <td class="cat">{labels[cls]}</td>
            </tr>
          );
        })}
      </tbody>
    </table>
  </div>
</div>
